{
  "name": "dotrepo-vscode",
  "displayName": "dotrepo",
  "description": "Thin VS Code extension for dotrepo manifest authoring.",
  "version": "1.0.0",
  "publisher": "dotrepo",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "dotrepo",
    "toml",
    "metadata",
    "repository"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/maxwellsantoro/dotrepo"
  },
  "bugs": {
    "url": "https://github.com/maxwellsantoro/dotrepo/issues"
  },
  "homepage": "https://github.com/maxwellsantoro/dotrepo#readme",
  "scripts": {
    "build": "esbuild extension.js --bundle --platform=node --format=cjs --external:vscode --minify --outfile=dist/extension.js",
    "package": "npm run build && npm run package:vsix -- --output dotrepo-vscode.vsix",
    "package:vsix": "python3 ../../scripts/package_vscode_extension.py --extension-root ."
  },
  "main": "./dist/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onLanguage:dotrepo",
    "onLanguage:dotrepo-overlay",
    "onCommand:dotrepo.validateCurrentManifest",
    "onCommand:dotrepo.trustCurrentManifest",
    "onCommand:dotrepo.doctorCurrentManifest",
    "onCommand:dotrepo.generateCheckCurrentManifest"
  ],
  "contributes": {
    "languages": [
      {
        "id": "dotrepo",
        "aliases": [
          "dotrepo"
        ],
        "filenames": [
          ".repo"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "dotrepo-overlay",
        "aliases": [
          "dotrepo overlay"
        ],
        "filenamePatterns": [
          "**/repos/*/*/*/record.toml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "dotrepo.validateCurrentManifest",
        "title": "dotrepo: Validate Current Manifest"
      },
      {
        "command": "dotrepo.trustCurrentManifest",
        "title": "dotrepo: Trust Current Manifest"
      },
      {
        "command": "dotrepo.doctorCurrentManifest",
        "title": "dotrepo: Doctor Current Root"
      },
      {
        "command": "dotrepo.generateCheckCurrentManifest",
        "title": "dotrepo: Generate Check Current Root"
      }
    ],
    "configuration": {
      "title": "dotrepo",
      "properties": {
        "dotrepo.languageServer.command": {
          "type": "string",
          "default": "dotrepo-lsp",
          "description": "Command used to launch the dotrepo language server."
        },
        "dotrepo.languageServer.args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Arguments passed to the dotrepo language server command."
        },
        "dotrepo.cli.command": {
          "type": "string",
          "default": "dotrepo",
          "description": "Command used for thin VS Code shell commands such as validate, trust, doctor, and generate --check."
        },
        "dotrepo.cli.args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Arguments passed before the dotrepo CLI subcommand and root arguments."
        }
      }
    }
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "vscode-languageclient": "^9.0.1"
  }
}
