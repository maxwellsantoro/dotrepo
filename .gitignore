.env
index-autonomous-batch/
output/
target/

# Local agent scratch space (e.g. Claude Code worktrees) must never be tracked.
.claude/worktrees/
# macOS Finder metadata
.DS_Store
**/.DS_Store

# Python bytecode caches
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Python tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

node_modules/
editors/vscode/dist/
editors/vscode/*.tgz
editors/vscode/*.vsix
index/.crawler-state.toml

# macOS AppleDouble / resource fork / extended attribute metadata files
# These have been a constant source of noise in git status/diff across the repo
._*
**/\._*
