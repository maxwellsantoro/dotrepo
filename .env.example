# Copy to `.env` and fill in values:
#   cp .env.example .env
#
# Load before local crawler/batch runs, e.g.:
#   set -a && source .env && set +a
#   uv run python scripts/run_autonomous_index_batch.py --skip-automation-enabled-check
#
# Adjudication tiers call a small HTTP sidecar (not OpenRouter directly).
# The sidecar holds OPENROUTER_API_KEY and translates dotrepo adjudication
# requests into OpenRouter chat completions. Point all three URLs at the same
# sidecar unless you run separate instances per tier.

# --- OpenRouter credential ---
# Create at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Tier 4 bearer auth (only tier 4 reads this today; keep in sync with OPENROUTER_API_KEY)
DOTREPO_ADJUDICATION_API_KEY=sk-or-v1-REPLACE_ME

# --- Tier 2: primary adjudicator (most calls) ---
DOTREPO_ADJUDICATION_URL=http://127.0.0.1:8787/adjudicate
DOTREPO_ADJUDICATION_PROVIDER=openrouter
DOTREPO_ADJUDICATION_MODEL=google/gemma-4-26b-a4b-it

# --- Tier 3: second opinion (low-confidence / disagreement) ---
DOTREPO_ADJUDICATION_SECOND_OPINION_URL=http://127.0.0.1:8787/adjudicate
DOTREPO_ADJUDICATION_SECOND_OPINION_PROVIDER=openrouter
DOTREPO_ADJUDICATION_SECOND_OPINION_MODEL=qwen/qwen3.5-9b

# --- Tier 4: rare tail escalation ---
DOTREPO_ADJUDICATION_API_URL=http://127.0.0.1:8787/adjudicate
DOTREPO_ADJUDICATION_API_PROVIDER=openrouter
DOTREPO_ADJUDICATION_API_MODEL=google/gemma-4-31b-it

# --- Autonomous index conveyor caps ---
INDEX_AUTOMATION_ENABLED=true
INDEX_MAX_ADJUDICATION_CALLS=10

# --- GitHub (required for dotrepo-crawler materialization) ---
# If this is set (even to a placeholder), `gh auth token` will not be used.
# Use a valid PAT or omit and rely on `gh auth login`.
GITHUB_TOKEN=ghp_REPLACE_ME